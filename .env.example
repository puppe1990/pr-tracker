# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GitHub Personal Access Token used by the backend to call the GitHub API.
# Recommended scopes for classic PAT: repo, read:user
# Fine-grained PAT must allow reading pull requests / repository metadata for the target repos.
GITHUB_PERSONAL_ACCESS_TOKEN=""
